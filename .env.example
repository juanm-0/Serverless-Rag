# Environment template for Serverless-Rag.
#
# Copy this file to `.env` and fill in the key(s) for the provider you use:
#     cp .env.example .env
# `.env` is gitignored and is auto-loaded by the CLI and eval harness.
# NEVER put real keys in this template or commit a real `.env`.

# Which LLM provider to use for answer generation: groq | gemini | anthropic
LLM_PROVIDER=groq

# --- Groq (free tier) --- get a key at https://console.groq.com -> API Keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (free tier) --- get a key at https://aistudio.google.com
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Anthropic Claude (paid) --- get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
